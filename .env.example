# ============================================================
#  نمونه‌ی فایل تنظیمات بازی کره زمین
#  این فایل را کپی کنید به نام .env و مقادیر واقعی را بگذارید.
#  (فایل .env هرگز در گیت قرار نمی‌گیرد — به .gitignore نگاه کنید)
# ============================================================

# --- توکن ربات تلگرام (از BotFather) ---
BOT_TOKEN=123456:ABC-YourTelegramBotToken

# --- اتصال به دیتابیس PostgreSQL ---
# قالب: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/earthgame

# --- اتصال به Groq (سوار بر کتابخانه‌ی openai) ---
GROQ_API_KEY=gsk_your_groq_api_key
GROQ_BASE_URL=https://api.groq.com/openai/v1
# شناسه‌ی مدل؛ در صورت نیاز بدون تغییر کد قابل عوض‌کردن است
AI_MODEL=openai/gpt-oss-120b
# حداکثر توکن خروجی هر پاسخ AI
AI_MAX_TOKENS=1500

# --- مالک و مدیران بازی (آی‌دی عددی تلگرام، با کاما جدا شوند) ---
# مالک‌ها درخواست‌های کشورگیری را تأیید/رد می‌کنند
OWNER_IDS=111111111
ADMIN_IDS=111111111,222222222

# --- کانال‌های خبری (آی‌دی عددی، معمولاً با -100 شروع می‌شود) ---
NEWS_MILITARY_CHANNEL_ID=-1000000000001
NEWS_DIPLOMACY_CHANNEL_ID=-1000000000002
NEWS_ECONOMY_CHANNEL_ID=-1000000000003

# --- سازمان انتقالات جهانی (محموله‌های تجاری) ---
WTO_CHANNEL_ID=-1000000000004

# --- گروه تماس تلفنی و گروه لاگ مدیران ---
PHONE_GROUP_ID=-1000000000005
LOG_GROUP_ID=-1000000000006
